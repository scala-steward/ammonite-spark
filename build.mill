      "SPARK_HOME"    -> sparkHome().path.toString,
      "SPARK_VERSION" -> sparkVersion()
    )
  }
}

object `standalone-tests` extends SbtModule with SparkTestsJvm {
  private def sv   = Versions.scala212
  def scalaVersion = sv
  def moduleDeps = super.moduleDeps ++ Seq(
    tests(sv)
  )

  object test extends SbtTests with AmmSparkTests {
    def forkEnv = Task {
      // Bring up the standalone master and worker before running the tests.
      sparkSlave()
      super.forkEnv() ++ Seq(
        "SPARK_HOME"               -> sparkHome().path.toString,
        "STANDALONE_SPARK_MASTER"  -> sparkMaster().master,
        "STANDALONE_SPARK_VERSION" -> sparkVersion()
      )
    }
  }
}

