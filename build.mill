object core extends Cross[Core](Versions.scala)
trait Core  extends CrossSbtModule with WithPropertyFile with AmmSparkPublishModule
    with AmmSparkMima {
  def artifactName = "ammonite-spark"
  def compileMvnDeps = super.compileMvnDeps() ++ Seq(
    Deps.ammoniteReplApi,
    Deps.sparkSql(scalaVersion())
  )
  def mvnDeps = super.mvnDeps() ++ Seq(
    Deps.classPathUtil,
    Deps.jettyServer
  )
  def propertyFilePath =
    os.sub / "org/apache/spark/sql/ammonitesparkinternals/ammonite-spark.properties"
  def versionInProperties = publishVersion()
  def propResourcesDir = Task(persistent = true) {
    import sys.process._

    val dir = Task.dest / "property-resources"
    val ver = publishVersion()

    val f =
      dir / "org/apache/spark/sql/ammonitesparkinternals/ammonite-spark.properties"

    val contentStr =
      s"""commit-hash=${Seq("git", "rev-parse", "HEAD").!!.trim}
         |version=$ver
         |""".stripMargin

    val content           = contentStr.getBytes("UTF-8")
    val currentContentOpt = if (os.exists(f)) Some(os.read.bytes(f)) else None

    if (!os.exists(f) || !Arrays.equals(content, os.read.bytes(f))) {
      os.write.over(f, content, createFolders = true)
      System.err.println(s"Wrote $f")
    }

    PathRef(dir)
  }
  def resources = Task {
    super.resources() ++ Seq(propResourcesDir())
  }

  def mimaPreviousVersions = Task {
    val needs =
      if (scalaVersion().startsWith("2.12.")) "v0.9.0"
      else "v0.13.0"
    os.proc("git", "tag", "--merged", "HEAD^", "--contains", needs)
      .call()
      .out.lines()
      .map(_.trim)
      .filter(_.startsWith("v"))
      .map(_.stripPrefix("v"))
  }
}

// Spark version used to build the local distribution and run the standalone
// cluster tasks below. Only 2.4 version published with Scala 2.12.
def sparkVersion = Task("2.4.2")

// Build a local Spark distribution and return its SPARK_HOME.
// Download a lightweight Spark distrib, run its jar-fetching script, then
// drop Spark's REPL jar in favour of our stubs.
def sparkHome = Task {
  val ver = sparkVersion()
  val url =
    "https://github.com/scala-cli/lightweight-spark-distrib/releases/download/v0.0.4/" +
      s"spark-$ver-bin-hadoop2.7-scala2.12.tgz"

  val cache    = coursier.cache.FileCache()
  val artifact = coursier.util.Artifact(url)
  val archive = cache.file(artifact).run.unsafeRun(true)(using cache.ec) match {
    case Left(err)   => throw new Exception(s"Error downloading $url: ${err.describe}", err)
    case Right(file) => os.Path(file)
  }

  os.proc("tar", "-zxf", archive)
    .call(cwd = Task.dest, stdin = os.Inherit, stdout = os.Inherit)

  val sparkDir = os.list(Task.dest)
    .filter(os.isDir)
    .find(_.last.startsWith(s"spark-$ver-"))
    .getOrElse(sys.error(s"No spark-$ver-* directory found after extracting $archive"))

  // The lightweight distrib only ships a script that downloads the actual jars.
  os.proc(sparkDir / "fetch-jars.sh")
    .call(cwd = sparkDir, stdin = os.Inherit, stdout = os.Inherit)

  // Drop Spark's own REPL jar and use our stubs in its place.
  for (jar <- os.list(sparkDir / "jars") if jar.last.startsWith("spark-repl_"))
    os.remove(jar)
  os.copy.into(`spark-stubs_24`.jar().path, sparkDir / "jars")

  PathRef(sparkDir)
}

// Spark 2.4 only runs on Java 8, while the Mill build itself runs on a newer
// JVM. Fetch a JDK 8 through the coursier-jvm API so the standalone master and
// worker scripts (which honour JAVA_HOME) launch with the right JVM.
def java8Home = Task {
  val fileCache = coursier.cache.FileCache()
  val jvmCache = coursier.jvm.JvmCache()
    .withArchiveCache(coursier.cache.ArchiveCache().withCache(fileCache))
    .withDefaultIndex
  val javaHome = coursier.jvm.JavaHome().withCache(jvmCache)
  val home     = javaHome.get("8").unsafeRun()(using fileCache.ec)
  PathRef(os.Path(home.getAbsolutePath))
}

// Env to run a subprocess under the fetched JDK 8: JAVA_HOME pointing at it, and
// its bin/ prepended to PATH (os.proc propagates the parent env by default).
private def java8Env(java8: os.Path): Map[String, String] =
  Map(
    "JAVA_HOME" -> java8.toString,
    "PATH"      -> s"${java8 / "bin"}${java.io.File.pathSeparator}${sys.env.getOrElse("PATH", "")}"
  )

// Host the standalone cluster binds to
def standaloneClusterHost = "localhost"

// Handle on a running Spark standalone master. `master` is the SPARK_MASTER URL;
// close() stops the master.
class SparkMasterHandle(
  home: os.Path,
  val master: String,
  extraEnv: Map[String, String]
) extends AutoCloseable {
  private def close0(check: Boolean = true): Unit =
    os.proc(home / "sbin" / "stop-master.sh")
      .call(cwd = home, env = extraEnv, check = check, stdin = os.Inherit, stdout = os.Inherit)
  def tryClose(): Unit =
    close0(check = false)
  def close(): Unit =
    close0()
}

// Handle on a running Spark standalone worker (slave); close() stops it.
class SparkSlaveHandle(
  home: os.Path,
  extraEnv: Map[String, String]
) extends AutoCloseable {
  private def close0(check: Boolean = true): Unit =
    os.proc(home / "sbin" / "stop-slave.sh")
      .call(cwd = home, env = extraEnv, check = check, stdin = os.Inherit, stdout = os.Inherit)
  def tryClose(): Unit =
    close0(check = false)
  def close(): Unit =
    close0()
}

// Start a Spark standalone master against the local distribution
def sparkMaster = Task.Worker {
  val home      = sparkHome().path
  val host      = standaloneClusterHost
  val masterUrl = s"spark://$host:7077"
  val env       = java8Env(java8Home().path)
  val handle    = new SparkMasterHandle(home, masterUrl, env)
  handle.tryClose()
  os.proc(home / "sbin" / "start-master.sh", "--host", host)
    .call(cwd = home, env = env, stdin = os.Inherit, stdout = os.Inherit)
  handle
}

// Start a Spark standalone worker (slave) attached to sparkMaster
def sparkSlave = Task.Worker {
  val home   = sparkHome().path
  val host   = standaloneClusterHost
  val master = sparkMaster().master
  val env    = java8Env(java8Home().path)
  val handle = new SparkSlaveHandle(home, env)
  handle.tryClose()
  os.proc(home / "sbin" / "start-slave.sh", "--host", host, master, "-c", "4", "-m", "4g")
    .call(cwd = home, env = env, stdin = os.Inherit, stdout = os.Inherit)
  handle
}

// All modules whose artifacts the tests need to resolve at runtime, via the
// `import $ivy.`sh.almond::ammonite-spark:…`` in the embedded Ammonite REPL
// (which also pulls the matching spark-stubs_* dynamically through coursier).
def publishModules: Seq[AmmSparkPublishModule] =
  Seq(`spark-stubs_24`, `spark-stubs_30`) ++
    `spark-stubs_32`.crossModules ++
    core.crossModules ++
    `almond-spark`.crossModules ++
    `almond-toree-spark`.crossModules

// Gather the publishLocalTestRepo of every module into a single local Maven
// repository, so tests can resolve the just-built artifacts without polluting
// ~/.ivy2/local via publishLocal.
def testRepo = Task {
  val repoDirs = Task.traverse(publishModules)(_.publishLocalTestRepo)()
  val dest     = Task.dest / "repo"
  for (repo <- repoDirs)
    os.copy(repo.path, dest, mergeFolders = true, replaceExisting = true, createFolders = true)
  PathRef(dest)
}

trait AmmSparkTests extends TestModule {
  def testFramework = "utest.runner.Framework"
  def forkArgs =
    super.forkArgs() ++ Seq("-Xmx3g", "-Dfoo=bzz") ++ sparkAddOpens
  def forkEnv = super.forkEnv() ++ Seq(
    "COURSIER_REPOSITORIES" -> {
      val repoUrl = testRepo().path.toNIO.toUri.toASCIIString
      s"$repoUrl|central"
    }
  )
}

// Spark 3.x doesn't officially support Java 17 (only 8/11), so run the modules
// hosting Spark tests - and their forked tests, which inherit javaHome from their
// enclosing module - on Java 11. The Mill build itself runs on Java 17, and Mill 1
// can't fork tests on Java 8 (its test bootstrap relies on java.lang.ProcessHandle).
trait SparkTestsJvm extends JavaModule {
  def jvmId = "temurin:11"
}

// Spark accesses JDK internals that the module system locks down since Java 9, so
// it needs these --add-opens to run on Java 11+ (Spark itself only started passing
// them automatically in 3.3).
def sparkAddOpens = Seq(
  "-XX:+IgnoreUnrecognizedVMOptions",
  "--add-opens=java.base/java.lang=ALL-UNNAMED",
  "--add-opens=java.base/java.lang.invoke=ALL-UNNAMED",
  "--add-opens=java.base/java.lang.reflect=ALL-UNNAMED",
  "--add-opens=java.base/java.io=ALL-UNNAMED",
  "--add-opens=java.base/java.net=ALL-UNNAMED",
  "--add-opens=java.base/java.nio=ALL-UNNAMED",
  "--add-opens=java.base/java.util=ALL-UNNAMED",
  "--add-opens=java.base/java.util.concurrent=ALL-UNNAMED",
  "--add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED",
  "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED",
  "--add-opens=java.base/sun.nio.cs=ALL-UNNAMED",
  "--add-opens=java.base/sun.security.action=ALL-UNNAMED",
  "--add-opens=java.base/sun.util.calendar=ALL-UNNAMED",
  "--add-opens=java.security.jgss/sun.security.krb5=ALL-UNNAMED"
)

