  object test extends CrossSbtTests with AmmSparkTests
}

object `local-spark-distrib-tests` extends SbtModule with SparkTestsJvm {
  private def sv   = Versions.scala212
  def scalaVersion = sv
  def moduleDeps = super.moduleDeps ++ Seq(
    tests(sv)
  )

  object test extends SbtTests with AmmSparkTests {
